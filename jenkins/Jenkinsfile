pipeline {
    agent any

    parameters{
        choice(name: 'BROWSER', choices: ['CHROME', 'EDGE'], description: 'Select Browser')
        string(name: 'TAGS', defaultValue: '@Test1', description: 'Enter Cucumber tags')
    }

    stages {
          stage('Checkout') {
            steps {
                echo "Checking........"
                checkout scm
            }
        }
        
        stage('Build') {
            steps {
                echo "Building........"
                bat 'mvn clean compile'
            }
        }
        stage('Test') {
            steps {
                echo "Testing........"
                bat "mvn test -Dbrowser=${params.BROWSER} -Dcucumber.filter.tags=\"${params.TAGS}\""
            }
        }
        stage('Report') {
            steps {
                echo "Reporting........"
                archiveArtifacts artifacts: 'target/*.json', fingerprint: true
            }
        }
    }
}
