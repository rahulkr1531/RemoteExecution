pipeline {
    agent any
    parameters {
        choice(name: 'BROWSER', choices: ['CHROME', 'EDGE'], description: 'Select Browser')
        string(name: 'TAGS', defaultValue: '@Test1', description: 'Enter Cucumber tags')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean compile'
            }
        }

        stage('Test') {
            steps {
                bat "bat "mvn clean verify -Dbrowser=${params.BROWSER} -Dcucumber.filter.tags=${params.TAGS}""
            }
        }

        stage('Report') {
            steps {
                // echo "Reporting........"
                // archiveArtifacts artifacts: 'target/*.json', fingerprint: true

                echo "Reports will be generated automatically in Maven verify phase"
                publishHTML([
                        reportDir: 'target/cucumber-reports',
                        reportFiles: 'overview-features.html',
                        reportName: 'Masterthought Report'
                ])
            }
        }
    }
}
